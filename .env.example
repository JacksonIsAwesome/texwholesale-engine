# ---- Core ----
# Local dev uses SQLite automatically. On Railway, add a Postgres plugin and it
# will inject DATABASE_URL for you.
DATABASE_URL=

# ---- Optional AI scoring / copywriting ----
ANTHROPIC_API_KEY=

# ---- ATTOM property + buyer data (real API calls when set) ----
ATTOM_API_KEY=
ATTOM_BASE=https://api.developer.attomdata.com
ATTOM_BUYER_PATH=/transaction/aggregation

# ---- Optional enrichments ----
USPS_USER_ID=
GOOGLE_MAPS_API_KEY=
BATCHDATA_API_KEY=
TRACERFY_API_KEY=

# ---- Scrapers (ALL OFF by default) ----
# Review each site's Terms of Service and robots.txt before enabling.
# When enabled, wire the per-site parser in sources.py first.
ENABLE_ZILLOW_SCRAPER=false
ENABLE_COUNTY_SCRAPER=false
ENABLE_TAX_DELINQUENT_SCRAPER=false
ENABLE_HUD_SCRAPER=false
ENABLE_PROBATE_SCRAPER=false
ENABLE_CODE_VIOLATION_SCRAPER=false
ENABLE_TX_SOS_SCRAPER=false
ENABLE_TREC_SCRAPER=false
ENABLE_HARD_MONEY_SCRAPER=false

# ---- Demo ----
# true = populate the dashboard with realistic sample leads/buyers (no keys needed)
DEMO_MODE=false
